<section class="rounded-[1.75rem] border border-slate-200/70 bg-white/90 p-6 shadow-[0_20px_45px_rgba(15,23,42,0.06)] backdrop-blur">
  <div class="flex items-center justify-between gap-3">
    <div>
      <p class="text-sm font-medium text-slate-500"><%= series_panel_component.eyebrow %></p>
      <h2 class="mt-1 text-xl font-semibold tracking-tight text-slate-950"><%= series_panel_component.title %></h2>
    </div>
    <span class="rounded-full bg-slate-100 px-3 py-1 text-xs font-semibold text-slate-600">
      <%= series_panel_component.count %> registros
    </span>
  </div>

  <div class="mt-6 rounded-[1.5rem] border border-slate-200 bg-[linear-gradient(180deg,_rgba(248,250,252,0.96)_0%,_rgba(255,255,255,1)_100%)] p-4">
    <div class="flex items-end justify-between gap-4">
      <div>
        <p class="text-xs font-semibold uppercase tracking-[0.2em] text-slate-400">Tendência recente</p>
        <p class="mt-2 text-2xl font-semibold tracking-tight text-slate-950">
          <%= format_metric(series_panel_component.items.first&.value, series_panel_component.unit) %>
        </p>
      </div>
      <p class="text-xs text-slate-500">
        De <%= series_panel_component.items.last&.reference_date&.strftime("%d/%m/%Y") || "-" %>
        até <%= series_panel_component.items.first&.reference_date&.strftime("%d/%m/%Y") || "-" %>
      </p>
    </div>

    <svg viewBox="0 0 420 140" class="mt-4 h-40 w-full">
      <defs>
        <linearGradient id="<%= series_panel_component.gradient_id %>" x1="0%" y1="0%" x2="0%" y2="100%">
          <stop offset="0%" stop-color="<%= series_panel_component.gradient_color %>" stop-opacity="0.28"></stop>
          <stop offset="100%" stop-color="<%= series_panel_component.gradient_color %>" stop-opacity="0"></stop>
        </linearGradient>
      </defs>

      <g class="text-slate-200">
        <line x1="12" y1="12" x2="408" y2="12" stroke="currentColor" stroke-dasharray="4 6"></line>
        <line x1="12" y1="70" x2="408" y2="70" stroke="currentColor" stroke-dasharray="4 6"></line>
        <line x1="12" y1="128" x2="408" y2="128" stroke="currentColor" stroke-dasharray="4 6"></line>
      </g>

      <% if series_panel_component.area_path.present? %>
        <path d="<%= series_panel_component.area_path %>" fill="url(#<%= series_panel_component.gradient_id %>)"></path>
      <% end %>

      <% if series_panel_component.line_path.present? %>
        <path d="<%= series_panel_component.line_path %>" fill="none" stroke-width="3" stroke-linecap="round" stroke-linejoin="round" class="<%= series_panel_component.stroke_class %>"></path>
      <% end %>
    </svg>
  </div>

  <div class="mt-6 overflow-hidden rounded-2xl border border-slate-200">
    <table class="min-w-full divide-y divide-slate-200 text-sm">
      <thead class="bg-slate-50 text-left text-xs font-semibold uppercase tracking-[0.18em] text-slate-500">
        <tr>
          <th class="px-4 py-3">Data</th>
          <th class="px-4 py-3">Valor</th>
        </tr>
      </thead>
      <tbody class="divide-y divide-slate-100 bg-white">
        <% series_panel_component.items.each do |item| %>
          <tr class="transition hover:bg-slate-50">
            <td class="px-4 py-3 text-slate-600"><%= item.reference_date.strftime("%d/%m/%Y") %></td>
            <td class="px-4 py-3 font-semibold text-slate-900"><%= format_metric(item.value, series_panel_component.unit) %></td>
          </tr>
        <% end %>
      </tbody>
    </table>
  </div>
</section>
