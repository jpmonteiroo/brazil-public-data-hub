<div class="min-h-screen bg-[radial-gradient(circle_at_top,_rgba(14,165,233,0.14),_transparent_34%),linear-gradient(180deg,_#f8fbff_0%,_#eef4ff_45%,_#f8fafc_100%)]">
  <div class="mx-auto w-full max-w-7xl px-4 py-6 sm:px-6 lg:px-8 lg:py-10">
    <section class="relative overflow-hidden rounded-[2rem] border border-white/70 bg-slate-950 text-white shadow-[0_30px_80px_rgba(15,23,42,0.18)]">
      <div class="absolute inset-0 bg-[radial-gradient(circle_at_top_right,_rgba(56,189,248,0.35),_transparent_28%),radial-gradient(circle_at_left,_rgba(16,185,129,0.2),_transparent_24%)]"></div>
      <div class="absolute -right-16 top-10 h-48 w-48 rounded-full bg-cyan-400/20 blur-3xl"></div>
      <div class="absolute bottom-0 left-1/3 h-40 w-40 rounded-full bg-emerald-300/10 blur-3xl"></div>

      <div class="relative grid items-center gap-10 px-6 py-8 sm:px-8 lg:grid-cols-[minmax(0,1.35fr)_minmax(320px,0.9fr)] lg:px-10 lg:py-10">
        <div class="max-w-3xl">
          <div class="inline-flex items-center gap-2 rounded-full border border-white/15 bg-white/10 px-3 py-1 text-xs font-medium tracking-[0.22em] text-cyan-100 uppercase backdrop-blur">
            <span class="h-2 w-2 rounded-full bg-emerald-400"></span>
            Dados oficiais do Brasil
          </div>

          <h1 class="mt-5 text-4xl font-semibold tracking-tight text-white sm:text-5xl">
            Brazil Public Data Hub
          </h1>

          <p class="mt-4 max-w-2xl text-sm leading-7 text-slate-200 sm:text-base">
            Visualize indicadores de fontes oficiais com um painel mais claro, centralizado e pronto para acompanhar
            sincronizações, séries econômicas e recortes geográficos em um só lugar.
          </p>

          <div class="mt-8 flex flex-col items-start gap-3 sm:flex-row sm:flex-wrap sm:items-center">
            <%= button_to "Atualizar dados agora",
                          sync_public_data_path,
                          method: :post,
                          class: "inline-flex items-center justify-center rounded-2xl bg-white px-5 py-3 text-sm font-semibold text-slate-950 transition hover:-translate-y-0.5 hover:bg-cyan-50" %>

            <div class="inline-flex items-center gap-3 rounded-2xl border border-white/15 bg-white/10 px-4 py-3 text-sm text-slate-100 backdrop-blur">
              <span class="inline-flex h-9 w-9 items-center justify-center rounded-xl bg-emerald-400/15 text-emerald-300">BR</span>
              <div>
                <p class="font-medium text-white">Painel nacional</p>
                <p class="text-xs text-slate-300">APIs do Banco Central e IBGE</p>
              </div>
            </div>
          </div>
        </div>

        <div class="grid gap-4 sm:grid-cols-3 lg:grid-cols-1">
          <%= render @page.hero_stat_cards %>
        </div>
      </div>
    </section>

    <% if notice.present? %>
      <div class="mx-auto mt-6 max-w-5xl rounded-2xl border border-emerald-200 bg-emerald-50/90 px-4 py-3 text-sm font-medium text-emerald-800 shadow-sm backdrop-blur">
        <%= notice %>
      </div>
    <% end %>

    <section class="mx-auto mt-6 grid max-w-6xl gap-4 md:grid-cols-2 xl:grid-cols-4">
      <%= render @page.stat_cards %>

      <article class="rounded-3xl border border-slate-200/70 bg-slate-950 p-6 text-white shadow-[0_16px_40px_rgba(15,23,42,0.12)]">
        <p class="text-sm font-medium text-slate-300">Sincronizações recentes</p>
        <p class="mt-4 text-3xl font-semibold tracking-tight"><%= @page.recent_syncs_count %></p>
        <p class="mt-4 text-sm leading-6 text-slate-300">
          Histórico consolidado das execuções mais recentes para acompanhar sucesso, falhas e volume importado.
        </p>
      </article>
    </section>

    <section class="mx-auto mt-6 grid max-w-6xl gap-6 xl:grid-cols-[minmax(0,1.45fr)_minmax(320px,0.75fr)]">
      <div class="grid gap-6 lg:grid-cols-2">
        <%= render @page.series_panels %>
      </div>

      <div class="grid gap-6">
        <section class="rounded-[1.75rem] border border-slate-200/70 bg-white/90 p-6 shadow-[0_20px_45px_rgba(15,23,42,0.06)] backdrop-blur">
          <div class="flex items-center justify-between gap-3">
            <div>
              <p class="text-sm font-medium text-slate-500">Cobertura territorial</p>
              <h2 class="mt-1 text-xl font-semibold tracking-tight text-slate-950">Unidades Federativas</h2>
            </div>
            <span class="rounded-full bg-emerald-50 px-3 py-1 text-xs font-semibold text-emerald-700">
              <%= @page.state_chips.size %> UFs
            </span>
          </div>

          <div class="mt-6 grid grid-cols-2 gap-3 sm:grid-cols-3">
            <%= render @page.state_chips %>
          </div>
        </section>

        <section class="rounded-[1.75rem] border border-slate-200/70 bg-white/90 p-6 shadow-[0_20px_45px_rgba(15,23,42,0.06)] backdrop-blur">
          <div class="flex items-center justify-between gap-3">
            <div>
              <p class="text-sm font-medium text-slate-500">Pipeline</p>
              <h2 class="mt-1 text-xl font-semibold tracking-tight text-slate-950">Sincronizações recentes</h2>
            </div>
            <span class="rounded-full bg-slate-100 px-3 py-1 text-xs font-semibold text-slate-600">Últimas 10</span>
          </div>

          <div class="mt-6 space-y-3">
            <%= render @page.sync_run_components %>
          </div>
        </section>
      </div>
    </section>
  </div>
</div>
